<script>
document.addEventListener('DOMContentLoaded', () => {
  const fills = document.querySelectorAll('.layer-fill');
  const targets = ['100%','12%','100%','96%','100%'];
  fills.forEach((f,i) => {
    f.style.width = '0%';
    setTimeout(() => { f.style.width = targets[i]; }, 900 + i * 120);
  });
});
</script>

</body>
